rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/staff_roles/$(request.auth.uid)).data.role;
    }
    
    function isStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/staff_roles/$(request.auth.uid));
    }
    
    function isAdmin() {
      return isSignedIn() && getRole() == 'admin';
    }
    
    // --- Rules ---

    // STAFF ROLES - Critical security collection
    match /staff_roles/{userId} {
      // Users can read their own role
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Only Admin (via backend/console) should write here
      // But we allow the Admin user to write via dashboard if needed
      allow write: if isAdmin();
    }
    
    // MENU ITEMS
    match /menu_items/{itemId} {
      // Guests can browse
      allow read: if true;
      // Only Admin can change items/prices
      allow write: if isAdmin();
    }
    
    // ORDERS
    match /orders/{orderId} {
      // Guests can fetch their own order by ID (but not list all)
      allow get: if true;
      // Staff can list and view all orders
      allow list: if isStaff();
      
      // Anyone can CREATE an order
      allow create: if true
        && request.resource.data.roomNumber is string
        && request.resource.data.items is list
        && request.resource.data.totalAmount is number
        // Force initial status
        && request.resource.data.status in ['pending', 'awaiting_payment'];
      
      // Only staff can update status or details
      // Kitchen role should be view only, but we'll let them update if we decide to
      // Based on previous mandate: "kitchen role CANNOT update order statuses"
      allow update: if isStaff() && getRole() != 'kitchen';
      
      // Only Admin or department staff can delete/cleanup
      allow delete: if isAdmin() || (isStaff() && getRole() != 'kitchen');
    }
    
    // ORDER HISTORY
    match /order_history/{orderId} {
      // Only staff can see history
      allow read: if isStaff();
      // Only staff can write to history (archiving)
      allow write: if isStaff() && getRole() != 'kitchen';
    }
    
    // GUESTS
    match /guests/{guestId} {
      // Only staff can manage guest data
      allow read, write: if isStaff();
    }
    
    // SETTINGS
    match /settings/{settingId} {
      // Public needs to read settings (e.g. if shop is closed)
      allow read: if true;
      // Only Admin can change settings
      allow write: if isAdmin();
    }
    
    // SECTIONS
    match /sections/{sectionId} {
      // Public needs to read available login sections
      allow read: if true;
      // Only Admin can manage sections
      allow write: if isAdmin();
    }
    
    // HOUSEKEEPING REQUESTS
    match /housekeeping_requests/{requestId} {
      // Guests can create
      allow create: if true;
      // Staff can manage
      allow read, update, delete: if isStaff();
    }
    
    // DEFAULT DENY
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
